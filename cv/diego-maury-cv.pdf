         <pdfx:ecv-data>{"_id":"6914cc23f9f1fd87569f86e8","style":{"background":"b00","colors":["#000000","#14324c"],"columnLayoutOption":1,"fontBody":"opensans","fontHeading":"raleway","fontSize":1,"headerExtraSpacing":0,"isMetaDataDisabled":true,"layout":"flipped_modern","layoutSize":"medium","lineHeightOption":0,"marginOption":0,"pageMarginOption":0,"record":"ResumeStyle"},"header":{"contacts":"","customHeight":188,"dateOfBirth":"","email":"dm@diegomaury.mx","extraField":"","extraLink":"diegomaury.mx","height":95,"link":"https://www.linkedin.com/in/diegomaury/","location":"Mexico (GMT-6)","name":"Diego Maury","nationality":"","phone":"(+52) 56 5926 7516","photo":"","photoStyle":"round","record":"Header","showDateOfBirth":false,"showEmail":true,"showExtraField":false,"showExtraLink":true,"showLink":true,"showLocation":true,"showNationality":false,"showPhone":true,"showPhoto":false,"showTitle":true,"title":"Community &amp;amp; Programs Manager | Specialist in Startup Acceleration | High-Impact Communication &amp;amp; Innovation","uppercaseName":true},"sections":[{"__t":"SummarySection","column":0,"enabled":true,"height":28,"items":[{"height":202,"id":"34pjdz511g","record":"SummaryItem","alignment":"justify","text":"&lt;div&gt;&lt;strong&gt;Innovation &amp;amp; Entrepreneurship Program Leader&lt;/strong&gt;, &lt;strong&gt;Startup Acceleration Specialist&lt;/strong&gt;, and &lt;strong&gt;Ecosystem Builder&lt;/strong&gt; with &lt;b&gt;10+ years&lt;/b&gt; designing and scaling high-impact programs across LATAM. Experienced in &lt;strong&gt;open innovation&lt;/strong&gt;, &lt;strong&gt;social entrepreneurship&lt;/strong&gt;, &lt;strong&gt;digital transformation&lt;/strong&gt;, and &lt;strong&gt;multi-stakeholder collaboration&lt;/strong&gt; with universities, governments, corporations, and NGOs.&lt;/div&gt;&lt;div&gt;&lt;br&gt;Recognized as &lt;strong&gt;the youngest author to develop a sustainable entrepreneurship methodology&lt;/strong&gt;, &lt;strong&gt;Redux&lt;/strong&gt;, adopted in educational and entrepreneurial communities.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Skilled in designing &lt;strong&gt;acceleration pathways&lt;/strong&gt;, facilitating &lt;strong&gt;workshops and bootcamps&lt;/strong&gt;, mentoring 100+ founders, and leading national innovation initiatives. Passionate about enabling mission-driven entrepreneurs through &lt;strong&gt;systems thinking&lt;/strong&gt;, &lt;strong&gt;qualitative research&lt;/strong&gt;, and &lt;strong&gt;impact-focused program design&lt;/strong&gt;.&lt;/div&gt;"}],"name":"","record":"SummarySection","showTitle":true},{"__t":"ExperienceSection","column":0,"enabled":true,"height":28,"items":[{"dateRange":{"fromMonth":null,"fromYear":2025,"isOngoing":true,"ongoingText":"","record":"DateRange","toMonth":null,"toYear":null},"table":{"cols":2,"record":"TableItem","rows":[["&lt;b&gt;Project name&lt;/b&gt;","&lt;b&gt;Description&lt;/b&gt;"],["",""]]},"height":275,"id":"njtk8mriv6","record":"ExperienceItem","alignment":"justify","bullets":["Led Revenue Operations and Growth strategy, aligning marketing, sales, and operations into a &lt;b&gt;unified revenue engine&lt;/b&gt;.","Designed and implemented &lt;b&gt;end-to-end revenue funnels&lt;/b&gt;, integrating acquisition, lead validation, lifecycle management, and pipeline governance within HubSpot.","&lt;b&gt;Structured &lt;/b&gt;the&lt;b&gt; commercial tech stack&lt;/b&gt;: Meta Ads acquisition, automated lead ingestion and qualification via Make, CRM governance, and WhatsApp integration for follow-up acceleration.","Reduced lead friction and improved speed-to-contact through automation workflows and standardized lead status architecture.","Built revenue visibility frameworks enabling data-driven decision-making across founder and commercial leadership teams.","&lt;b&gt;Translated growth strategy into executable processes&lt;/b&gt;, balancing rapid experimentation with operational control and responsible scaling.","Established &lt;b&gt;RevOps governance practices &lt;/b&gt;connecting demand generation, sales execution, and revenue forecasting."],"companyLogo":"https://enhancv.s3.amazonaws.com/company-logos-cache/fliphouseabilene.com.png","description":"","link":"","location":"","position":"Strategic RevOps &amp;amp; Growth Manager","showBullets":true,"showCompany":true,"showDateRange":true,"showDescription":false,"showLink":false,"showLocation":false,"showTable":true,"showTitle":true,"workplace":"FlipHouse"},{"dateRange":{"fromMonth":null,"fromYear":2024,"isOngoing":true,"ongoingText":"","record":"DateRange","toMonth":null,"toYear":null},"table":{"cols":2,"record":"TableItem","rows":[["&lt;b&gt;Project name&lt;/b&gt;","&lt;b&gt;Description&lt;/b&gt;"],["",""]]},"height":195,"id":"trz1a8smmn","record":"ExperienceItem","alignment":"justify","bullets":["Implemented &lt;b&gt;automation&lt;/b&gt;,&lt;b&gt; AI tools&lt;/b&gt;, and &lt;b&gt;CRM &lt;/b&gt;systems for &lt;b&gt;digitalization&lt;/b&gt;, boosting efficiency and customer growth.","&lt;strong&gt;Systematized&lt;/strong&gt; program data using &lt;strong&gt;CRM&lt;/strong&gt; tools to enhance reporting and decision-making.","Integrated &lt;strong&gt;systems-thinking approaches&lt;/strong&gt; to diagnose social challenges and design high-impact entrepreneurship programs.","Facilitated smooth &lt;b&gt;onboarding processes for social entrepreneurs&lt;/b&gt;, ensuring accurate needs assessments and alignment with &lt;strong&gt;Fellowship support pathways&lt;/strong&gt;.","Coordinated with &lt;strong&gt;investors, mentors, and senior leaders&lt;/strong&gt; to deliver high-value learning experiences and accelerate venture growth."],"companyLogo":"https://enhancv.s3.amazonaws.com/company-logos-cache/diegomaury.mx.png","description":"","link":"","location":"","position":"Strategic Business &amp;amp; Innovation Manager","showBullets":true,"showCompany":true,"showDateRange":true,"showDescription":false,"showLink":false,"showLocation":false,"sh